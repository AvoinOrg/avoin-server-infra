SEAWEEDFS_IMAGE=chrislusf/seaweedfs:4.37
SEAWEEDFS_DATA_DIR=./volumes/seaweedfs
SEAWEEDFS_VOLUME_MAX=64
SEAWEEDFS_VOLUME_MIN_FREE_SPACE=2GiB
SEAWEEDFS_S3_CACHE_MB=128

# Compatibility server for legacy Supabase public image URLs:
# /object/public/<bucket>/<key> and /render/image/public/<bucket>/<key>.
IMAGE_SERVER_SUPABASE_PREFIX=storage-single-tenant
IMAGE_SERVER_CACHE_CONTROL=public, max-age=31536000, immutable

# Legacy Supabase Storage settings. These are only needed when running
# docker compose --profile legacy-supabase up -d.
GLOBAL_S3_BUCKET=
GLOBAL_S3_ENDPOINT=
GLOBAL_S3_PROTOCOL=
GLOBAL_S3_FORCE_PATH_STYLE=
REGION=

POSTGRES_USER=supabase_admin
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=
POSTGRES_DATA_DIR=

JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

# If you set these then imgproxy rejects unsigned urls
# IMGPROXY_KEY=
# IMGPROXY_SALT=
