# ---------- General ----------
COMPOSE_PROJECT_NAME=estate-postgis-loader

# Absolute host path for source files, work files, generated verification
# output, and other large artifacts. Keep this outside git.
ESTATE_DATA_PATH=/srv/estate-postgis-loader

# ---------- Images ----------
# The tools image is built from a pinned GDAL base and adds psql.
ESTATE_TOOLS_IMAGE=estate-postgis-loader-tools:0.1.0
GDAL_BASE_IMAGE=ghcr.io/osgeo/gdal:ubuntu-small-3.10.3
POSTGRES_CLIENT_IMAGE=postgres:16.9-alpine

# ---------- Source package ----------
# Operator-staged NLS/MML Kiinteistörekisterikartta (vektori) GeoPackage path
# inside the tools container. Mount source files below ESTATE_DATA_PATH/source.
SOURCE_FILE=/data/source/kiinteistorekisterikartta.gpkg
SOURCE_FORMAT=GPKG
SOURCE_CRS=EPSG:3067

# Confirm these names with `ogrinfo` for the downloaded package before import.
SOURCE_PARCEL_LAYER=PalstanSijaintitiedot
SOURCE_ESTATE_ID_FIELD=kiinteistotunnus
SOURCE_ESTATE_DISPLAY_FIELD=kiinteistotunnuksenEsitysmuoto
SOURCE_FEATURE_ID_FIELD=fid

# Optional operator/source metadata. Leave blank when unknown; the import script
# fills source filename, file size, SHA-256, and retrieval time from SOURCE_FILE.
SOURCE_FILENAME=
SOURCE_FILE_SIZE_BYTES=
SOURCE_SHA256=
SOURCE_JOB_ID=
SOURCE_RETRIEVED_AT=
NLS_DELIVERY_OR_ORDER_TIME=
SOURCE_REGISTRY_STATE_DATE=
SOURCE_REGISTRY_STATE_CURRENT=

# Public attribution stored in estate.source_metadata.
SOURCE_PROVIDER=National Land Survey of Finland / Maanmittauslaitos
SOURCE_DATASET_NAME=Kiinteistörekisterikartta (vektori) / Cadastral index map (vector)
SOURCE_PRODUCT_URL=https://www.maanmittauslaitos.fi/en/maps-and-spatial-data/datasets-and-interfaces/product-descriptions/cadastral-index-map-vector
SOURCE_LICENSE=CC BY 4.0
SOURCE_ATTRIBUTION=National Land Survey of Finland / Maanmittauslaitos, Kiinteistörekisterikartta (vektori), acquired by operator
SOURCE_ACQUISITION_METHOD=operator-staged-gpkg

# ---------- Sandbox PostGIS ----------
# Use real values only in ignored .env or the operator secret channel.
POSTGIS_HOST=sandbox-postgis.example.invalid
POSTGIS_PORT=5432
POSTGIS_ADMIN_DB=postgres
POSTGIS_DB=geocoding-finland
POSTGIS_USER=estate_loader
POSTGIS_PASSWORD=replace-with-sandbox-password
PGCONNECT_TIMEOUT=15

# Scripts abort unless both values are exactly geocoding-finland.
ESTATE_LOADER_CONFIRM_DB=geocoding-finland

# Generated by verify-estates.sh. This path is inside ESTATE_DATA_PATH and is
# intentionally ignored when ESTATE_DATA_PATH points inside this folder.
VERIFY_OUTPUT_PATH=/data/reports/estate-verification.txt
