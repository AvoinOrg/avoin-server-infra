# ---------- General ----------
DOMAIN=kan.avoin.org
DATA_PATH=/home/avoin/kan-data

# Kan publishes container images under the latest tag.
KAN_IMAGE_TAG=latest
NEXT_PUBLIC_BASE_URL=https://kan.avoin.org
BETTER_AUTH_SECRET=change_me_32_plus_random_chars
KAN_ADMIN_API_KEY=change_me_admin_api_key
LOG_LEVEL=info
NEXT_API_BODY_SIZE_LIMIT=50mb

# ---------- Database ----------
POSTGRES_PASSWORD=change_me_strong_postgres_password

# ---------- Email ----------
# Live Dokploy values should use the Avoin SES SMTP submission proxy.
SMTP_HOST=smtp.avoin.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true
EMAIL_FROM=Kan <kan@avoin.org>
NEXT_PUBLIC_DISABLE_EMAIL=false

# ---------- Auth ----------
NEXT_PUBLIC_ALLOW_CREDENTIALS=false
NEXT_PUBLIC_DISABLE_SIGN_UP=false
BETTER_AUTH_TRUSTED_ORIGINS=https://kan.avoin.org
BETTER_AUTH_ALLOWED_DOMAINS=avoin.org

# Zitadel generic OIDC. Create a Zitadel web application with redirect URI:
# https://kan.avoin.org/api/auth/oauth2/callback/oidc
# Then fill the client values in Dokploy; the discovery URL can stay as-is.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=https://auth.avoin.org/.well-known/openid-configuration

# ---------- Integrations ----------
TRELLO_APP_API_KEY=
TRELLO_APP_SECRET=

# ---------- Branding ----------
NEXT_PUBLIC_WHITE_LABEL_HIDE_POWERED_BY=true

# ---------- Optional rate limiting ----------
REDIS_URL=

# ---------- Optional S3 storage ----------
# Leave these empty until a public storage domain is chosen, for example
# kan-s3.avoin.org. Kan reports storage as "not_configured" when unset.
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=
S3_AVATAR_UPLOAD_LIMIT=
NEXT_PUBLIC_STORAGE_URL=
NEXT_PUBLIC_AVATAR_BUCKET_NAME=
NEXT_PUBLIC_ATTACHMENTS_BUCKET_NAME=
NEXT_PUBLIC_STORAGE_DOMAIN=
NEXT_PUBLIC_USE_VIRTUAL_HOSTED_URLS=
