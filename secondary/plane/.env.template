# ---------- General ----------
DOMAIN=plane.avoin.org
DATA_PATH=/home/avoin/plane-data

# Pin Plane to the release whose compose file this stack is based on.
APP_RELEASE=v1.3.1

# Plane sits behind the secondary Traefik proxy. Keep SITE_ADDRESS as :80 so
# Plane's internal proxy serves plain HTTP to Traefik.
WEB_URL=https://plane.avoin.org
CORS_ALLOWED_ORIGINS=https://plane.avoin.org
API_BASE_URL=http://api:8000
SITE_ADDRESS=:80
TRUSTED_PROXIES=0.0.0.0/0
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory

DEBUG=0
GUNICORN_WORKERS=1
API_KEY_RATE_LIMIT=60/minute
FILE_SIZE_LIMIT=5242880

# ---------- Database ----------
POSTGRES_DB=plane
POSTGRES_USER=plane
POSTGRES_PASSWORD=change_me_strong_postgres_password

# ---------- Redis ----------
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# ---------- RabbitMQ ----------
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=change_me_strong_rabbitmq_password
RABBITMQ_VHOST=plane

# ---------- Plane secrets ----------
SECRET_KEY=change_me_64_plus_random_chars
LIVE_SERVER_SECRET_KEY=change_me_64_plus_random_chars
MACHINE_SIGNATURE=change_me_64_plus_random_chars
AES_SECRET_KEY=change_me_64_plus_random_chars
SILO_HMAC_SECRET_KEY=change_me_64_plus_random_chars
WEBHOOK_SECRET=change_me_64_plus_random_chars

# ---------- Object storage ----------
USE_MINIO=1
AWS_REGION=
AWS_ACCESS_KEY_ID=change_me_minio_access_key
AWS_SECRET_ACCESS_KEY=change_me_strong_minio_secret_key
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
MINIO_ENDPOINT_SSL=0

# Webhook allowlists should usually stay empty. Add only trusted internal
# webhook destinations if Plane needs to call private-network URLs.
WEBHOOK_ALLOWED_IPS=
WEBHOOK_ALLOWED_HOSTS=

# Plane outgoing SMTP and OIDC are configured in /god-mode after first-run
# instance setup. See README.md in this directory.
